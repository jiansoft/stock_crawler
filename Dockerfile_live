FROM alpine:3.23

RUN apk add --no-cache ca-certificates tzdata openssl

ENV TZ=Asia/Taipei
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

WORKDIR /app

EXPOSE 9001

# Built by build.bat:
#   target/aarch64-unknown-linux-musl/release/stock_crawler
COPY ./stock_crawler /app/stock_crawler
RUN chmod +x /app/stock_crawler

COPY ./.env /app/.env
COPY ./app.json /app/app.json

RUN addgroup -g 1001 -S appgroup && \
    adduser -u 1001 -S appuser -G appgroup && \
    mkdir -p /app/log /opt/nginx/ssl/jiansoft.mooo.com && \
    chown -R appuser:appgroup /app /opt/nginx/ssl/jiansoft.mooo.com

VOLUME ["/app/log","/opt/nginx/ssl/jiansoft.mooo.com"]

USER appuser

CMD ["/app/stock_crawler"]
